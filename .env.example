# =============================================
# AnaMaria Morrison Website — Environment Variables
# Copy to .env.local and fill in real values
# NEVER commit .env.local to git
# =============================================

# Resend (Email transaccional — Fase 2)
# Get it at: resend.com
RESEND_API_KEY=re_your_resend_api_key

# Anthropic API (PR Auto-Pilot scoring — Fase 5)
# Get it at: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Supabase (PR Auto-Pilot DB — Fase 5)
# Get from: app.supabase.com > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# PR Auth (JWT secret — 64+ chars)
# Generate: openssl rand -hex 32
PR_AUTH_SECRET=your_64_char_hex_secret_generated_with_openssl

# PR Webhook Secret (64+ chars)
# Generate: openssl rand -hex 32
PR_AUTOPILOT_WEBHOOK_SECRET=your_64_char_webhook_secret_generated_with_openssl

# Google Analytics (Fase 3)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console verification (Fase 3)
NEXT_PUBLIC_GOOGLE_VERIFICATION=your_verification_code

# Site URL
NEXT_PUBLIC_SITE_URL=https://anamorrison.com

# =============================================
# Social Stats (auto-update de seguidores)
# Todas son opcionales — si faltan, se usa el fallback manual de
# src/data/socialStatsFallback.ts. La página nunca se rompe.
# =============================================

# ── Instagram + Facebook Page (Meta Graph API) ──
# 1) Crear app en developers.facebook.com
# 2) Vincular tu cuenta IG Business/Creator a una Página de FB
# 3) Generar long-lived Page Access Token con permisos:
#    instagram_basic, pages_show_list, pages_read_engagement
# 4) Obtener IG Business ID: GET /me/accounts?fields=instagram_business_account
META_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_PAGE_ID=

# ── YouTube Data API v3 ──
# 1) console.cloud.google.com → habilitar YouTube Data API v3
# 2) Credentials → Create API key (restringir a YouTube Data API)
# 3) Channel ID: youtube.com/account_advanced (UC...)
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# ── TikTok (opcional, hoy follower_count sólo via TikTok for Business) ──
# Cuenta personal/creator NO expone follower_count en API oficial.
# Si en el futuro consigues acceso, configurar:
TIKTOK_ACCESS_TOKEN=

# ── LinkedIn (opcional, sólo Company Pages, no perfil personal) ──
# Requiere app aprobada para Marketing Developer Platform.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=
